<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nails For You – Richmond Hill</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --cream:      #f5f0ea;
    --linen:      #ede6db;
    --sand:       #d9cfc3;
    --taupe:      #b5a596;
    --warm-taupe: #9e8e80;
    --deep-taupe: #7a6a5e;
    --dark:       #3d3530;
    --accent:     #c8aa8e;
    --white:      #fdfaf6;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Jost', sans-serif;
    background: var(--cream);
    color: var(--dark);
    font-weight: 300;
  }

  /* ── HEADER ─────────────────────────────────── */
  header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: var(--white);
    border-bottom: 1px solid var(--sand);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    height: 70px;
    box-shadow: 0 2px 20px rgba(122,106,94,0.08);
  }

  .logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.45rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--deep-taupe);
    line-height: 1.1;
  }
  .logo span { display: block; font-size: 0.72rem; font-weight: 300; letter-spacing: 0.22em; text-transform: uppercase; color: var(--taupe); }

  nav { display: flex; gap: 32px; align-items: center; }
  nav a {
    text-decoration: none;
    font-size: 0.82rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--warm-taupe);
    transition: color 0.2s;
  }
  nav a:hover { color: var(--deep-taupe); }

  .btn-book {
    background: var(--deep-taupe);
    color: var(--white) !important;
    padding: 10px 22px;
    border-radius: 2px;
    font-weight: 700 !important;
    font-size: 0.78rem !important;
    letter-spacing: 0.18em !important;
    transition: background 0.2s !important;
  }
  .btn-book:hover { background: var(--dark) !important; }

  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
  .hamburger span { display: block; width: 24px; height: 2px; background: var(--deep-taupe); }

  /* ── HERO ────────────────────────────────────── */
  .hero {
    min-height: 92vh;
    background: linear-gradient(160deg, var(--linen) 0%, var(--sand) 55%, var(--taupe) 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 60px 24px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='40' cy='40' r='1' fill='%23b5a596' fill-opacity='0.18'/%3E%3C/svg%3E") repeat;
    pointer-events: none;
  }

  .hero-eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--deep-taupe);
    margin-bottom: 18px;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
  }
  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 300;
    line-height: 1.05;
    color: var(--dark);
    opacity: 0;
    animation: fadeUp 0.8s 0.4s forwards;
  }
  .hero h1 em { font-style: italic; color: var(--deep-taupe); }
  .hero-sub {
    margin-top: 16px;
    font-size: 1rem;
    letter-spacing: 0.12em;
    color: var(--warm-taupe);
    opacity: 0;
    animation: fadeUp 0.8s 0.6s forwards;
  }/* ── ANNOUNCEMENT BAR ────────────────────────── */
.announcement-bar {
  background: #c5a36c; /* Gold color from your image */
  color: #000;
  overflow: hidden;
  white-space: nowrap;
  position: sticky;
  top: 0;
  z-index: 1100; /* Higher than header to stay on top */
  padding: 10px 0;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border-bottom: 1px solid rgba(0,0,0,0.1);
}

.announcement-track {
  display: inline-block;
  padding-left: 100%;
  animation: marquee 25s linear infinite;
}

.announcement-track span {
  display: inline-block;
  padding-right: 50px;
}

@keyframes marquee {
  0%   { transform: translate(0, 0); }
  100% { transform: translate(-100%, 0); }
}

/* Adjust Header Position */
header {
  top: 36px; /* Offsets header so it doesn't overlap the bar */
}

@media(max-width: 900px) {
  header {
    top: 36px;
  }
}

  .hero-actions {
    margin-top: 40px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
    opacity: 0;
    animation: fadeUp 0.8s 0.8s forwards;
  }

  .cta-primary {
    background: var(--deep-taupe);
    color: var(--white);
    padding: 15px 38px;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background 0.2s, transform 0.2s;
    border: none;
    cursor: pointer;
  }
  .cta-primary:hover { background: var(--dark); transform: translateY(-1px); }

  .cta-secondary {
    background: transparent;
    color: var(--deep-taupe);
    padding: 14px 36px;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    border-radius: 2px;
    border: 1.5px solid var(--taupe);
    transition: border-color 0.2s, color 0.2s;
    cursor: pointer;
  }
  .cta-secondary:hover { border-color: var(--deep-taupe); color: var(--dark); }

  /* Gift card hero card */
  .gift-hero {
    margin-top: 52px;
    background: var(--white);
    border: 1px solid var(--sand);
    border-radius: 6px;
    padding: 28px 40px;
    display: flex;
    align-items: center;
    gap: 24px;
    box-shadow: 0 8px 32px rgba(122,106,94,0.12);
    opacity: 0;
    animation: fadeUp 0.8s 1s forwards;
    max-width: 520px;
    width: 100%;
  }
  .gift-icon { font-size: 2.4rem; flex-shrink: 0; }
  .gift-text h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 600; color: var(--dark); }
  .gift-text p { font-size: 0.82rem; color: var(--warm-taupe); margin-top: 4px; }
  .gift-text a {
    display: inline-block;
    margin-top: 12px;
    background: var(--accent);
    color: var(--dark);
    padding: 9px 22px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.2s;
  }
  .gift-text a:hover { background: var(--taupe); color: var(--white); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── SECTIONS ────────────────────────────────── */
  section { padding: 88px 24px; }
  .container { max-width: 1100px; margin: 0 auto; }

  .section-label {
    font-size: 0.68rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--taupe);
    display: block;
    margin-bottom: 12px;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    color: var(--dark);
    line-height: 1.15;
  }
  .section-title em { font-style: italic; color: var(--deep-taupe); }
  .divider { width: 48px; height: 1px; background: var(--taupe); margin: 20px 0 32px; }

  /* ── ABOUT ────────────────────────────────────── */
  .about { background: var(--white); }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }
  .about-body { font-size: 0.97rem; line-height: 1.85; color: var(--warm-taupe); }
  .about-body p + p { margin-top: 16px; }

  .about-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 36px; }
  .stat { padding: 22px; background: var(--linen); border-radius: 4px; border-left: 3px solid var(--taupe); }
  .stat-num { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 600; color: var(--deep-taupe); }
  .stat-lbl { font-size: 0.75rem; letter-spacing: 0.12em; color: var(--warm-taupe); margin-top: 2px; }

  .about-img-stack { position: relative; height: 420px; }
  
  /* UPDATED CSS FOR IMAGES */
  .about-img-stack img { position: absolute; object-fit: cover; border-radius: 4px; }
  .img-back  { width: 78%; height: 88%; top: 0; right: 0; z-index: 1; }
  .img-front { width: 55%; height: 64%; bottom: 0; left: 0; box-shadow: 0 16px 48px rgba(122,106,94,0.18); border: 4px solid var(--white); z-index: 2; }

  /* Removed placeholder styles as they are no longer needed */

  /* ── SERVICES ──────────────────────────────────── */
  .services { background: var(--linen); }
  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 48px; }
  .service-card {
    background: var(--white);
    border-radius: 6px;
    padding: 36px 28px;
    border-bottom: 3px solid transparent;
    transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
  }
  .service-card:hover { border-color: var(--taupe); transform: translateY(-4px); box-shadow: 0 16px 40px rgba(122,106,94,0.12); }
  .service-icon { font-size: 2rem; margin-bottom: 16px; }
  .service-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 600; color: var(--dark); margin-bottom: 10px; }
  .service-card p { font-size: 0.86rem; line-height: 1.7; color: var(--warm-taupe); }
  .service-card .price { display: inline-block; margin-top: 16px; font-size: 0.78rem; letter-spacing: 0.1em; color: var(--deep-taupe); font-weight: 500; }

  /* ── DRINKS ─────────────────────────────────────── */
  .drinks { background: var(--deep-taupe); color: var(--white); }
  .drinks .section-label { color: var(--accent); }
  .drinks .section-title { color: var(--white); }
  .drinks .divider { background: var(--accent); }
  .drinks-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-top: 48px; }
  .drink-cat { background: rgba(255,255,255,0.08); border-radius: 6px; padding: 28px 22px; }
  .drink-cat h4 { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-weight: 600; color: var(--accent); margin-bottom: 12px; }
  .drink-cat ul { list-style: none; }
  .drink-cat ul li { font-size: 0.84rem; padding: 5px 0; color: rgba(255,255,255,0.78); border-bottom: 1px solid rgba(255,255,255,0.08); }
  .drink-cat ul li:last-child { border-bottom: none; }

  /* ── GIFT CARD SECTION ─────────────────────────── */
  .gift-section { background: var(--sand); }
  .gift-section-inner {
    background: var(--white);
    border-radius: 8px;
    padding: 64px 48px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    box-shadow: 0 8px 40px rgba(122,106,94,0.1);
  }
  .gift-card-visual {
    background: linear-gradient(135deg, var(--deep-taupe), var(--taupe), var(--accent));
    border-radius: 14px;
    padding: 40px 36px;
    color: var(--white);
    position: relative;
    overflow: hidden;
    min-height: 200px;
  }
  .gift-card-visual::before {
    content: '✦';
    position: absolute;
    right: 20px;
    bottom: 20px;
    font-size: 5rem;
    opacity: 0.15;
  }
  .gift-card-visual h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 300; }
  .gift-card-visual .gcname { font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase; opacity: 0.75; margin-top: 32px; }
  .gift-section-text h2 { font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 300; color: var(--dark); line-height: 1.2; }
  .gift-section-text p { margin-top: 16px; font-size: 0.9rem; line-height: 1.75; color: var(--warm-taupe); }
  .gift-section-text a { margin-top: 28px; display: inline-block; }

  /* ── FAQ ─────────────────────────────────────────── */
  .faq { background: var(--cream); }
  .faq-list { margin-top: 48px; display: flex; flex-direction: column; gap: 12px; }
  .faq-item { background: var(--white); border-radius: 4px; border: 1px solid var(--sand); overflow: hidden; }
  .faq-q {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 22px 28px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: 'Jost', sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--dark);
    letter-spacing: 0.02em;
    transition: background 0.2s;
  }
  .faq-q:hover { background: var(--linen); }
  .faq-q .arrow { font-size: 1.1rem; color: var(--taupe); transition: transform 0.3s; flex-shrink: 0; }
  .faq-a { display: none; padding: 0 28px 22px; font-size: 0.88rem; line-height: 1.8; color: var(--warm-taupe); }
  .faq-item.open .faq-a { display: block; }
  .faq-item.open .arrow { transform: rotate(180deg); }

  /* ── MAP / LOCATION ──────────────────────────────── */
  .location-section { background: var(--linen); }
  .location-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }
  .location-map-link {
    display: block;
    border-radius: 8px;
    overflow: hidden;
    border: 3px solid var(--sand);
    box-shadow: 0 12px 36px rgba(122,106,94,0.14);
    transition: transform 0.25s, box-shadow 0.25s;
    text-decoration: none;
    position: relative;
  }
  .location-map-link:hover { transform: translateY(-4px); box-shadow: 0 20px 48px rgba(122,106,94,0.2); }
  .location-map-link iframe { display: block; width: 100%; height: 320px; border: none; pointer-events: none; }
  .map-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 18px;
    background: linear-gradient(0deg, rgba(61,53,48,0.55) 0%, transparent 60%);
    border-radius: 6px;
  }
  .map-overlay span { color: var(--white); font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 500; }

  .location-info h2 { font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 300; color: var(--dark); }
  .location-detail { margin-top: 28px; display: flex; flex-direction: column; gap: 18px; }
  .loc-row { display: flex; gap: 16px; align-items: flex-start; }
  .loc-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 2px; }
  .loc-text strong { display: block; font-size: 0.78rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--taupe); font-weight: 500; }
  .loc-text span { font-size: 0.92rem; color: var(--warm-taupe); line-height: 1.6; }
  .hours-grid { margin-top: 6px; display: grid; grid-template-columns: 1fr 1fr; gap: 4px 20px; }
  .hours-grid span { font-size: 0.83rem; color: var(--warm-taupe); }

  /* ── TESTIMONIALS ────────────────────────────────── */
  .testimonials { background: var(--white); }
  .testi-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; margin-top: 48px; }
  .testi-card { background: var(--linen); border-radius: 6px; padding: 32px 28px; position: relative; }
  .stars { color: var(--accent); font-size: 1rem; margin-bottom: 14px; letter-spacing: 3px; }
  .testi-card p { font-size: 0.88rem; line-height: 1.78; color: var(--warm-taupe); font-style: italic; }
  .testi-author { margin-top: 18px; font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--taupe); font-weight: 500; }

  /* ── FOOTER ─────────────────────────────────────── */
  footer {
    background: var(--dark);
    color: rgba(255,255,255,0.6);
    padding: 56px 24px 32px;
  }
  .footer-grid { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 48px; }
  .footer-brand h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 600; color: var(--white); }
  .footer-brand p { margin-top: 12px; font-size: 0.85rem; line-height: 1.7; }
  .footer-col h4 { font-size: 0.72rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--accent); margin-bottom: 16px; }
  .footer-col a { display: block; color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.85rem; margin-bottom: 8px; transition: color 0.2s; }
  .footer-col a:hover { color: var(--white); }
  .footer-col h4 + a { margin-top: 16px; } /* Booking policy button */
  .footer-bottom { max-width: 1100px; margin: 40px auto 0; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.08); display: flex; justify-content: space-between; align-items: center; font-size: 0.78rem; }

  /* ── STICKY BOTTOM BAR (mobile) ────────────────────── */
  .sticky-bar {
    display: none;
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: var(--white);
    border-top: 1px solid var(--sand);
    padding: 10px 16px;
    gap: 10px;
    z-index: 999;
    box-shadow: 0 -4px 20px rgba(122,106,94,0.1);
  }
  .sticky-bar a { flex: 1; text-align: center; padding: 11px 6px; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; text-decoration: none; border-radius: 3px; }
  .sticky-bar .s-call { background: var(--linen); color: var(--deep-taupe); border: 1px solid var(--sand); }
  .sticky-bar .s-book { background: var(--deep-taupe); color: var(--white); font-weight: 700; }
  .sticky-bar .s-gift { background: var(--accent); color: var(--dark); }

  /* ── RESPONSIVE ─────────────────────────────────── */
  @media(max-width: 900px) {
    nav { display: none; }
    .hamburger { display: flex; }
    .about-grid, .location-grid, .gift-section-inner { grid-template-columns: 1fr; }
    .about-img-stack { height: 280px; }
    .services-grid { grid-template-columns: 1fr 1fr; }
    .drinks-grid { grid-template-columns: 1fr 1fr; }
    .testi-grid { grid-template-columns: 1fr; }
    .footer-grid { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; gap: 8px; text-align: center; }
    .sticky-bar { display: flex; }
    body { padding-bottom: 70px; }
  }
  @media(max-width: 580px) {
    .services-grid { grid-template-columns: 1fr; }
    .drinks-grid { grid-template-columns: 1fr 1fr; }
    .hero { min-height: 80vh; }
    .gift-hero { flex-direction: column; text-align: center; }
  }

  /* ── MOBILE NAV ─────────────────────────────────── */
  .mobile-nav {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--white);
    z-index: 2000;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 32px;
  }
  .mobile-nav.open { display: flex; }
  .mobile-nav a { font-size: 1.4rem; font-family: 'Cormorant Garamond', serif; color: var(--dark); text-decoration: none; letter-spacing: 0.08em; }
  .mobile-nav .close-btn { position: absolute; top: 22px; right: 28px; font-size: 1.6rem; cursor: pointer; color: var(--taupe); background: none; border: none; }
</style>
</head>
<body>

<!-- ANNOUNCEMENT BAR -->
<div class="announcement-bar">
  <div class="announcement-track">
    <span>✦ Shellac Mani + Pedi Combo — Starting at $80</span>
    <span>✦ Head Spa Special — Glamour Signature $69</span>
    <span>✦ 10% Off on Group Booking of 4 or More</span>
    <!-- Repeat to ensure smooth scrolling if the text is short -->
    <span>✦ Shellac Mani + Pedi Combo — Starting at $80</span>
    <span>✦ Head Spa Special — Glamour Signature $69</span>
    <span>✦ 10% Off on Group Booking of 4 or More</span>
  </div>
</div>  

<!-- MOBILE NAV -->
<div class="mobile-nav" id="mobileNav">
  <button class="close-btn" onclick="toggleMenu()">✕</button>
  <a href="#about" onclick="toggleMenu()">About Us</a>
  <a href="#services" onclick="toggleMenu()">Services</a>
  <a href="#drinks" onclick="toggleMenu()">Complimentary</a>
  <a href="#gift" onclick="toggleMenu()">Gift Cards</a>
  <a href="#faq" onclick="toggleMenu()">FAQ</a>
  <a href="#location" onclick="toggleMenu()">Contact</a>
  <a href="#" class="cta-primary" style="margin-top:8px;" onclick="toggleMenu()">Book Now</a>
</div>

<!-- HEADER -->
<header>
  <div class="logo">
    Nails For You
    <span>Richmond Hill</span>
  </div>
  <nav>
    <a href="#about">About</a>
    <a href="#services">Services</a>
    <a href="#drinks">Complimentary</a>
    <a href="#gift">Gift Cards</a>
    <a href="#faq">FAQ</a>
    <a href="#location">Contact</a>
    <a href="#" class="btn-book">Book Now</a>
  </nav>
  <div class="hamburger" onclick="toggleMenu()">
    <span></span><span></span><span></span>
  </div>
</header>

<!-- HERO -->
<section class="hero">
  <p class="hero-eyebrow">Richmond Hill's Premier Nail & Spa Studio</p>
  <h1>Nails For <em>You</em></h1>
